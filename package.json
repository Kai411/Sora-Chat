{
  "name": "sora",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"npm:dev --workspace apps/server\" \"npm:dev --workspace apps/web\"",
    "dev:server": "npm run dev --workspace apps/server",
    "dev:web": "npm run dev --workspace apps/web",
    "build": "npm run build --workspace apps/web"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
