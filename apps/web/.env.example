# Copy to .env (or .env.local) — Vite loads it automatically in dev.
# These are BUILD-TIME values: for the deployed site, set them in
# Netlify → Site configuration → Environment variables, then redeploy.

# Socket.IO server origin. Leave empty for same-origin (local dev uses the
# vite proxy). For the Netlify site, set your Render URL, no trailing slash:
# VITE_SERVER_URL=https://sora-server-xxxx.onrender.com
VITE_SERVER_URL=

# Google OAuth web client ID (Google Cloud console → Credentials).
# The Google Sign-In button only appears when this is set.
# Must match the server's GOOGLE_CLIENT_ID.
# VITE_GOOGLE_CLIENT_ID=1234567890-abc123.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=
