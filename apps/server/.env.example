# Copy to .env — the server loads it on boot when present.
# For the deployed server, set these in Render → Environment instead.

# Port to listen on (Render injects its own PORT automatically).
PORT=3001

# SQLite database file (created automatically).
DB_PATH=sora.db

# Same Supabase project as the web app (Settings → API). The server uses
# these to verify user access tokens against /auth/v1/user.
# SUPABASE_URL=https://abcdefghij.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Service role key (Settings → API → service_role — KEEP SECRET, server only).
# Enables persistence to Supabase Storage: the SQLite db is snapshotted to a
# private bucket and uploads (images/music) go to a public bucket, so data
# survives Render redeploys/spin-downs. Buckets are auto-created.
SUPABASE_SERVICE_KEY=

# LiveKit — powers live audio in party rooms. Free at cloud.livekit.io:
# create a project, then Settings → Keys gives you all three values.
# Without these, rooms show "live audio not configured" but work otherwise.
# LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
